{
  "name": "bede-tutor",
  "version": "0.1.0",
  "description": "Agnus Dei — Charlotte Mason Homeschool Tutor",
  "main": "dist-electron/main.js",
  "private": true,
  "scripts": {
    "dev": "concurrently -n renderer,electron -c cyan,yellow \"vite --port 5174\" \"wait-on http://localhost:5174 && cross-env ELECTRON_DEV=1 electron .\"",
    "build:renderer": "vite build",
    "build:electron": "tsc -p tsconfig.node.json",
    "build": "npm run build:renderer && npm run build:electron",
    "package:mac": "npm run build && electron-builder --mac",
    "package:win": "npm run build && electron-builder --win"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "wait-on": "^8.0.1"
  }
}
