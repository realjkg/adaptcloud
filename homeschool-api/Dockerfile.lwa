FROM python:3.11-slim

# Lightweight Agent build — omits Whisper and Resemblyzer to reduce image size
# and RAM footprint for Raspberry Pi 4 deployment.

WORKDIR /app

# System deps only (no audio/ML libraries)
RUN apt-get update && apt-get install -y --no-install-recommends \
        libpq5 \
        curl \
    && rm -rf /var/lib/apt/lists/*

# Python deps — exclude heavy ML packages
COPY requirements.txt .
RUN pip install --no-cache-dir \
    $(grep -v -E '^(openai-whisper|resemblyzer|librosa|soundfile|torch|torchaudio|numpy)' requirements.txt | grep -v '^#' | tr '\n' ' ')

COPY . .

# Non-root user matching the main Dockerfile
RUN useradd -u 1001 -M -s /sbin/nologin bede && chown -R bede:bede /app
USER bede

EXPOSE 8000

CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8000", \
     "--workers", "2", "--loop", "uvloop"]
