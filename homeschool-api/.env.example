# ── REQUIRED: change every value before running ──────────────────────────────

# Claude API key
ANTHROPIC_API_KEY=sk-ant-...

# JWT signing key — minimum 32 random characters
SECRET_KEY=generate-with-openssl-rand-hex-32

# Encryption master secret — minimum 32 random characters
# Changing this requires running the key-rotation procedure
MASTER_SECRET=generate-with-openssl-rand-hex-32

# Parent password (used for admin access + key derivation)
PARENT_PASSWORD=your-strong-parent-password

# Child PIN (4+ digits)
CHILD_PIN=1234

# ── Optional ──────────────────────────────────────────────────────────────────

CORS_ORIGINS=http://localhost:5173,http://localhost:80

# Set to "true" in production (disables /docs, /redoc)
DISABLE_API_DOCS=false
PRODUCTION=false

# Custom paths for encrypted key files (defaults to working directory)
# SAGE_DATA_KEY_FILE=/secure/data_key.enc
# SAGE_SALT_FILE=/secure/device.salt
