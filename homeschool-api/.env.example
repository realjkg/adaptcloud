# Copy this to .env and fill in every REPLACE_ME before running.
# Run `bash setup.sh` from the repo root to do this interactively.

ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# JWT signing key — generate with: openssl rand -hex 32
SECRET_KEY=REPLACE_ME

# Per-family encryption wrap key — generate with: openssl rand -hex 32
SERVER_KEY=REPLACE_ME

# PostgreSQL connection string
# Format: postgresql+asyncpg://user:password@host/dbname?ssl=require
DATABASE_URL=postgresql+asyncpg://REPLACE_ME

# ── Deployment URL (single source of truth for WebAuthn) ──────────────────────
#
# WebAuthn rpId and origin are auto-derived from this URL.
# Changing it after passkeys are enrolled invalidates existing credentials.
#
# Valid options (pick the one that matches your deployment):
#   http://localhost          — development, this machine only
#   https://bede.local        — LAN / home network (Caddy local CA)
#   https://agnusdei.ai       — public internet (real domain + TLS)
#
# IP addresses (e.g. https://192.168.1.10) are NOT supported —
# WebAuthn requires a hostname as the Relying Party ID.
SITE_URL=http://localhost:5173

# CORS allowed origins (SITE_URL is always included automatically)
CORS_ORIGINS=http://localhost:5173,http://localhost:80

DISABLE_API_DOCS=false
PRODUCTION=false

# ── Optional overrides (normally auto-derived from SITE_URL) ──────────────────
# WEBAUTHN_RP_NAME=Agnus Dei
# WEBAUTHN_RP_ID=                  # leave blank → hostname from SITE_URL
# WEBAUTHN_ORIGIN=                 # leave blank → scheme+host from SITE_URL
